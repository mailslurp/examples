<?xml version="1.0" encoding="UTF-8"?>
<!--
  MailSlurp SMS deliverability workflow using plain HTTP samplers.

  High-level flow:
  1) List phone numbers and choose one sender phone for simulation.
  2) Create deliverability test:
     - runType=ALL: selector.type=ALL and exclude sender.
     - runType=SINGLE: selector.type=EXPLICIT with second phone ID and exclude sender.
  3) Start the deliverability test.
  4) sendMode=SIMULATOR: create simulation job to send SMS to selected targets.
     sendMode=EXTERNAL: skip simulation and trigger your own SUT externally.
  5) Poll test status/progress every 15s until success/failure/timeout.

  Note: The sender phone is excluded from targets because telecom routing can allow
  self-delivery/loopback in some regions, which can distort test signal.
-->
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="MailSlurp SMS Deliverability + Simulation" enabled="true">
      <stringProp name="TestPlan.comments">Creates and runs a PHONE-scope deliverability test with SMS simulation using MailSlurp, then polls for completion.</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
