# MailSlurp API Key
# Get one free at https://app.mailslurp.com
MAILSLURP_API_KEY=your_api_key_here

# n8n Configuration
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=false

# Puppeteer Configuration
# Set to false to see browser window during testing
HEADLESS=true

# Chrome executable path (optional, auto-detected on most systems)
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
